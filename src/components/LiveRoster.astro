---
import Phone3D from './Phone3D.astro';
import SportShot from './SportShot.astro';
import { strings } from '../i18n';
import type { Lang } from '../i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const s = strings(lang);

const rows = s.roster.rows;
---

<section class="section section--tight roster">
  <div class="container">
    <span class="eyebrow reveal">{s.roster.eyebrow}</span>
    <h2 class="section-heading reveal">{s.roster.heading}</h2>

    <div class="roster-grid">
      <div class="roster-left">
        <ul class="roster-list">
          {
            rows.map((r, i) => (
              <li class="roster-row reveal" style={`--i:${i}`}>
                <span class="r-sport">{r.sport}</span>
                <span class="r-place">{r.place}</span>
                <span class="r-time">{r.time}</span>
                {r.full ? (
                  <span class="r-status pill-full">{r.slots}</span>
                ) : (
                  <span class="r-status">{r.slots}</span>
                )}
              </li>
            ))
          }
        </ul>
        <SportShot
          class="reveal roster-shot"
          src="/photos/court-wide.webp"
          alt={s.roster.shotAlt}
        />
        <p class="roster-note reveal">
          {s.roster.note}
        </p>
      </div>

      <Phone3D class="reveal" screen="/screens/squads.png" label={s.roster.phoneLabel} />
    </div>
  </div>
</section>

<style>
  .roster-grid {
    margin-top: var(--space-12);
    display: grid;
    gap: var(--space-12);
    align-items: start;
  }
  @media (min-width: 900px) {
    .roster-grid {
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 360px);
      gap: var(--space-12);
      align-items: center;
    }
  }
  .roster-list {
    list-style: none;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
  }
  .roster-row {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1.3fr) auto auto;
    align-items: center;
    gap: var(--space-4);
    padding: 18px var(--space-6);
    border-top: 1px solid var(--border);
  }
  .roster-row:first-child {
    border-top: none;
  }
  .r-sport {
    font-weight: 600;
  }
  .r-place,
  .r-time {
    color: var(--muted);
    font-size: 0.9375rem;
  }
  .r-status {
    justify-self: end;
    font-size: 0.875rem;
    color: var(--muted);
    white-space: nowrap;
  }
  .pill-full {
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: var(--tracking-tracked);
    padding: 5px 12px;
    border-radius: var(--r-full);
    background: var(--accent-500);
    color: var(--ink-900);
  }

  /* Hover de linha (só ponteiro): fundo afunda + barra lima entra pela esquerda */
  @media (hover: hover) {
    .roster-row {
      transition: background 0.2s var(--ease);
    }
    .roster-row::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      background: var(--accent-500);
      transform: scaleY(0);
      transform-origin: top;
      transition: transform 0.2s var(--ease);
    }
    .roster-row:hover {
      background: var(--sunken);
    }
    .roster-row:hover::before {
      transform: scaleY(1);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .roster-row,
    .roster-row::before {
      transition: none;
    }
  }

  @media (max-width: 680px) {
    .roster-row {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        'sport status'
        'place time';
      gap: 4px var(--space-4);
      padding: 16px var(--space-4);
    }
    .r-sport { grid-area: sport; }
    .r-status { grid-area: status; }
    .r-place { grid-area: place; }
    .r-time { grid-area: time; justify-self: start; }
  }
  :global(.roster-shot) {
    margin-top: var(--space-6);
    --shot-ratio: 21 / 9; /* faixa panorâmica: a cidade a jogar */
  }
  .roster-note {
    margin-top: var(--space-4);
    color: var(--muted);
    font-size: 0.9375rem;
  }
  .roster-phone {
    justify-self: center;
  }
</style>
