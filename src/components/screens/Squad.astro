---
import Icon from '../Icon.astro';

const roster = [
  { n: 'João M.', s: 'in' },
  { n: 'Ana R.', s: 'in' },
  { n: 'Pedro L.', s: 'in' },
  { n: 'Sofia V.', s: 'in' },
  { n: 'Diogo T.', s: 'in' },
  { n: 'Rui C.', s: 'in' },
  { n: 'Marta J.', s: 'maybe' },
  { n: 'Nuno F.', s: 'out' },
];
const initials = (n: string) =>
  n.split(' ').map((w) => w[0]).join('').slice(0, 2).toUpperCase();
---

<div class="app-screen sq">
  <span class="sq-grab" aria-hidden="true"></span>
  <div class="sq-head">
    <span class="app-eyebrow">Tue · 19:00</span>
    <div class="app-title sq-title">Footy at Parque Central</div>
    <div class="sq-meta">
      <span><Icon name="clock" size={13} /> in 4h</span>
      <span><Icon name="users" size={13} /> 10/10</span>
    </div>
  </div>

  <div class="sq-meter" aria-hidden="true"><span></span></div>

  <div class="sq-list">
    {
      roster.map((p, i) => (
        <div class="sq-row reveal" style={`--i:${i + 1}`}>
          <span class="app-avatar">{initials(p.n)}</span>
          <span class={`sq-name ${p.s === 'out' ? 'is-out' : ''}`}>{p.n}</span>
          {p.s === 'in' && <span class="app-pill pill-full">In</span>}
          {p.s === 'maybe' && <span class="app-pill app-pill--outline">Maybe</span>}
          {p.s === 'out' && (
            <span class="app-pill app-pill--outline">
              <Icon name="x" size={11} /> Out
            </span>
          )}
        </div>
      ))
    }
  </div>

  <button class="sq-cta" aria-hidden="true" tabindex="-1">
    <span class="sq-dot"></span> Lock the squad
  </button>
</div>

<style>
  .sq-grab { display: block; width: 36px; height: 4px; border-radius: 99px; background: var(--border); margin: 0 auto 4px; }
  .sq-title { font-size: 18px; line-height: 1.2; }
  .sq-meta { display: flex; gap: 14px; margin-top: 6px; font-size: 12px; color: var(--muted); }
  .sq-meta span { display: inline-flex; align-items: center; gap: 4px; }
  .sq-meter { height: 6px; border-radius: 99px; background: var(--sunken); overflow: hidden; }
  .sq-meter span { display: block; height: 100%; width: 100%; background: var(--accent-500); }
  .sq-list { display: grid; gap: 9px; margin-top: 2px; }
  .sq-row { display: flex; align-items: center; gap: 9px; }
  .sq-name { flex: 1; font-weight: 600; font-size: 13px; }
  .sq-name.is-out { color: var(--muted); text-decoration: line-through; }
  .sq-cta {
    margin-top: auto; display: flex; align-items: center; justify-content: center; gap: 8px;
    background: var(--fg); color: var(--bg); border: none; border-radius: var(--r-md);
    padding: 12px; font-weight: 600; font-size: 13px;
  }
  .sq-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--accent-500); }
</style>
