---
// Barra de estado iOS (horas + rede + wi-fi + bateria) para os mockups CSS.
// Posiciona-se ao lado da dynamic island do PhoneMockup (top 9px, h 22px).
// "9:41" é a hora clássica do marketing da Apple.
---

<div class="statusbar" aria-hidden="true">
  <span class="sb-time">9:41</span>
  <span class="sb-icons">
    <!-- rede celular: 4 barras -->
    <svg width="15" height="10" viewBox="0 0 18 12" fill="currentColor">
      <rect x="0" y="8" width="3" height="4" rx="1"></rect>
      <rect x="5" y="5.5" width="3" height="6.5" rx="1"></rect>
      <rect x="10" y="3" width="3" height="9" rx="1"></rect>
      <rect x="15" y="0" width="3" height="12" rx="1"></rect>
    </svg>
    <!-- wi-fi: 3 arcos -->
    <svg width="13" height="10" viewBox="0 0 16 12" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
      <path d="M1.5 4.2a10 10 0 0 1 13 0"></path>
      <path d="M3.9 6.9a6.4 6.4 0 0 1 8.2 0"></path>
      <path d="M6.3 9.5a2.8 2.8 0 0 1 3.4 0"></path>
      <circle cx="8" cy="11" r="0.9" fill="currentColor" stroke="none"></circle>
    </svg>
    <!-- bateria: contorno + carga -->
    <svg width="20" height="10" viewBox="0 0 25 12" fill="none">
      <rect x="0.6" y="0.6" width="20.8" height="10.8" rx="3" stroke="currentColor" stroke-width="1.1" opacity="0.45"></rect>
      <rect x="2.4" y="2.4" width="15.5" height="7.2" rx="1.6" fill="currentColor"></rect>
      <path d="M23.2 4 a 2 2 0 0 1 0 4 Z" fill="currentColor" opacity="0.45"></path>
    </svg>
  </span>
</div>

<style>
  .statusbar {
    position: absolute;
    top: 9px;
    left: 20px;
    right: 18px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 5; /* abaixo da island (6) */
    color: var(--fg);
    pointer-events: none;
  }
  .sb-time {
    font-size: 11.5px;
    font-weight: 650;
    letter-spacing: 0.01em;
    font-variant-numeric: tabular-nums;
  }
  .sb-icons {
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .sb-icons svg {
    display: block;
  }
</style>
