---
import '../styles/global.css';
import { strings } from '../i18n';
import type { Lang } from '../i18n';

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
  autoDetect?: boolean;
}

const { lang = 'pt', autoDetect = true } = Astro.props;
const s = strings(lang);
const title = Astro.props.title ?? s.meta.title;
const description = Astro.props.description ?? s.meta.description;
const ogImage = new URL('/og.png', Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang={s.meta.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>
    {/* Deteção de idioma: 1ª visita vai para a língua do browser; respeita a
        escolha guardada pelo seletor PT/EN. Corre cedo para evitar flash.
        Desligada nas páginas legais (autoDetect=false) para não reencaminhar. */}
    {
      autoDetect && (
        <script is:inline define:vars={{ current: lang }}>
          {`try {
            var saved = localStorage.getItem('skuader-lang');
            var nav = (navigator.language || 'en').toLowerCase();
            var want = saved || (nav.indexOf('pt') === 0 ? 'pt' : 'en');
            if (want !== current) location.replace(want === 'en' ? '/en' : '/');
          } catch (e) {}`}
        </script>
      )
    }
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />

    <!-- Partilha em redes sociais (tags independentes do domínio) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="skuader" />
    <meta property="og:locale" content={s.meta.ogLocale} />
    <link rel="canonical" href={canonical} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Boldonse&family=Inter:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />

    <script>
      const sel =
        '.reveal, .strike, .underscore, .pill-full, .mark-swipe, .ring-arc, .countup';
      const els = Array.from(document.querySelectorAll(sel));
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Count-up: guarda o valor final e arranca a 0 (só com motion).
      // Sem JS / reduced-motion → fica o valor final renderizado no HTML.
      const parseNum = (s) => String(s).match(/^(\D*)([\d.,]+)(\D*)$/);
      const counters = Array.from(document.querySelectorAll('.countup'));
      counters.forEach((el) => {
        el.dataset.target = el.textContent.trim();
      });
      if (!reduce) {
        counters.forEach((el) => {
          const m = parseNum(el.dataset.target);
          if (m) el.textContent = m[1] + '0' + m[3];
        });
      }
      function tweenCount(el) {
        const m = parseNum(el.dataset.target || el.textContent);
        if (!m) return;
        const prefix = m[1],
          suffix = m[3],
          numStr = m[2].replace(/,/g, ''),
          end = parseFloat(numStr),
          decimals = (numStr.split('.')[1] || '').length,
          dur = 900,
          t0 = performance.now();
        function frame(t) {
          const p = Math.min(1, (t - t0) / dur);
          const v = end * (1 - Math.pow(1 - p, 3));
          el.textContent = prefix + (decimals ? v.toFixed(decimals) : Math.round(v)) + suffix;
          if (p < 1) requestAnimationFrame(frame);
          else el.textContent = prefix + m[2] + suffix;
        }
        requestAnimationFrame(frame);
      }

      if (reduce || !('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                if (e.target.classList.contains('countup')) tweenCount(e.target);
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.18, rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach((el) => io.observe(el));

        // Parallax subtil das wordmarks (hero + fecho)
        const para = Array.from(document.querySelectorAll('[data-parallax]'));
        if (para.length) {
          let ticking = false;
          const update = () => {
            const vh = window.innerHeight;
            for (const el of para) {
              const r = el.getBoundingClientRect();
              const d = (r.top + r.height / 2 - vh / 2) * -0.06;
              (el as HTMLElement).style.transform = `translateY(${d.toFixed(1)}px)`;
            }
            ticking = false;
          };
          window.addEventListener(
            'scroll',
            () => {
              if (!ticking) {
                requestAnimationFrame(update);
                ticking = true;
              }
            },
            { passive: true }
          );
          update();
        }
      }
    </script>
  </body>
</html>
